# === LLM Model Configuration ===
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1

# Best for agent simulation: high-volume (150 agents), fast MoE (5.1B active), 90% MMLU, 81+ language foundation
LLM_MODEL_NAME=openai/gpt-oss-120b:free

# Best for report generation: excellent JSON output, designed for agentic/reasoning tasks
LLM_REASONING_MODEL=nousresearch/hermes-3-llama-3.1-405b:free

# Output language for all LLM responses. Set to Lithuanian for VU Physics simulation.
# Set to "Chinese" to disable language injection (original OASIS behaviour).
OUTPUT_LANGUAGE=Lithuanian

# Forum host moderator model
FORUM_HOST_MODEL_NAME=openai/gpt-oss-120b:free

# Fallback model when primary hits rate limits (3.5B active params, very fast throughput)
# LLM_MODEL_NAME=nvidia/nemotron-3-nano-30b-a3b:free

# AVOID these models for MiroFish:
# - qwen/qwen3-coder:free        → documented JSON output bugs when reasoning enabled
# - stepfun/step-3.5-flash:free  → XML-biased, Chinese+English only
# - z-ai/glm-4.5-air:free        → Chinese-primary model

# ===== ZEP记忆图谱配置 =====
# 每月免费额度即可支撑简单使用：https://app.getzep.com/
# 如果使用本地 Docker 部署 (docker-compose-zep.yml)，请取消注释以下行并保留 API_KEY 为空或任意值
# ZEP_API_URL=http://localhost:8000
ZEP_API_KEY=your_zep_api_key_here

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== UNIFIED ENGINES CONFIGURATION (可选) =====
# 注意：Docker env_file 不支持 ${VAR} 变量插值，必须使用完整URL
# INSIGHT_ENGINE_API_KEY=your_api_key_here
# INSIGHT_ENGINE_BASE_URL=https://openrouter.ai/api/v1
# INSIGHT_ENGINE_MODEL_NAME=minimax/minimax-m2.5:free
# MEDIA_ENGINE_API_KEY=your_api_key_here
# MEDIA_ENGINE_BASE_URL=https://openrouter.ai/api/v1
# MEDIA_ENGINE_MODEL_NAME=minimax/minimax-m2.5:free
# REPORT_ENGINE_API_KEY=your_api_key_here
# REPORT_ENGINE_BASE_URL=https://openrouter.ai/api/v1
# REPORT_ENGINE_MODEL_NAME=minimax/minimax-m2.5:free


# ===== Flask配置 =====
# Docker环境中建议设为False
FLASK_DEBUG=False