# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 使用 OpenRouter 免费模型
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1

# Recommended models for Lithuanian language quality (OpenRouter free tier):
#   Best:        meta-llama/llama-3.3-70b-instruct:free  (strong multilingual, good Lithuanian)
#   Alternative: google/gemini-flash-1.5:free            (good European language support)
#   Avoid:       minimax/minimax-m2.5:free               (Chinese-optimized, poor Lithuanian)
LLM_MODEL_NAME=meta-llama/llama-3.3-70b-instruct:free
LLM_REASONING_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ===== ZEP记忆图谱配置 =====
# 每月免费额度即可支撑简单使用：https://app.getzep.com/
# 如果使用本地 Docker 部署 (docker-compose-zep.yml)，请取消注释以下行并保留 API_KEY 为空或任意值
# ZEP_API_URL=http://localhost:8000
ZEP_API_KEY=your_zep_api_key_here

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== UNIFIED ENGINES CONFIGURATION (可选) =====
# 注意：Docker env_file 不支持 ${VAR} 变量插值，必须使用完整URL
# INSIGHT_ENGINE_API_KEY=your_api_key_here
# INSIGHT_ENGINE_BASE_URL=https://openrouter.ai/api/v1
# INSIGHT_ENGINE_MODEL_NAME=minimax/minimax-m2.5:free
# MEDIA_ENGINE_API_KEY=your_api_key_here
# MEDIA_ENGINE_BASE_URL=https://openrouter.ai/api/v1
# MEDIA_ENGINE_MODEL_NAME=minimax/minimax-m2.5:free
# REPORT_ENGINE_API_KEY=your_api_key_here
# REPORT_ENGINE_BASE_URL=https://openrouter.ai/api/v1
# REPORT_ENGINE_MODEL_NAME=minimax/minimax-m2.5:free

# ===== OUTPUT LANGUAGE =====
# Language injected as header into every LLM system prompt.
# Set to "Lithuanian" for VU Physics simulation (agents respond in Lithuanian).
# Set to "English" for generic use. Set to "Chinese" to disable injection entirely.
OUTPUT_LANGUAGE=Lithuanian

# ===== Flask配置 =====
# Docker环境中建议设为False
FLASK_DEBUG=False